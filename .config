# Target 架构 X86_64
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_PARTSIZE=1024
CONFIG_ARCH_64BIT=y
CONFIG_ALL_KMODS=n
CONFIG_ALL_NONSHARED=n

# 基础系统工具
CONFIG_PACKAGE_openssh-server=y
CONFIG_PACKAGE_btop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_kmod-usb-storage=y

# 防火墙4 nftables (不切换iptables)
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-offload=y

# ========= BCM943602CDP 博通无线驱动（关键）========
CONFIG_PACKAGE_kmod-brcm-wl=y
CONFIG_PACKAGE_wlc=y
CONFIG_PACKAGE_brcmfmac-firmware=n
CONFIG_PACKAGE_kmod-brcmfmac=n
CONFIG_PACKAGE_wireless-tools=y
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_wpad-basic-wolfssl=y
# 蓝牙
CONFIG_PACKAGE_kmod-bluetooth=y
CONFIG_PACKAGE_bluez-libs=y
CONFIG_PACKAGE_bluez-utils=y

# LuCI 主题 仅保留Argon
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-theme-alpha=n
CONFIG_PACKAGE_luci-theme-material=n

# ========= 核心 LuCI-APP 清单 =========
# 主题设置 & 商店 & 运维
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-timedreboot=y
CONFIG_PACKAGE_luci-app-watchcat=y

# DNS & 去广告
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-app-adguardhome=y

# 代理 & 订阅
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE-luci-app-subconverter=y

# 监控 & 流量
CONFIG_PACKAGE_luci-app-netdata=y
CONFIG_PACKAGE-luci-app-nlbwmon=y

# 组网 & DDNS
CONFIG_PACKAGE_luci-app-ddns-go=y
CONFIG_PACKAGE-luci-app-tailscale-community=y

# WiFi 配套
CONFIG_PACKAGE-luci-app-wifischedule=y
CONFIG_PACKAGE-luci-app-arpbind=y
CONFIG_PACKAGE-luci-app-airplay2=y

# 安全 & 推送
CONFIG_PACKAGE-luci-app-acme=y
CONFIG_PACKAGE-luci-app-wechatpush=y
CONFIG_PACKAGE-luci-app-nft-timecontrol=y

# ========= Docker 核心（新增）========
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_dockerd=y

# 可选小众工具（按需保留）
# CONFIG_PACKAGE_luci-app-socat=y
# CONFIG_PACKAGE_luci-app-vlmcsd=y
# CONFIG_PACKAGE_luci-app-uugamebooster=y

# ========= 强制关闭冗余插件 =========
CONFIG_PACKAGE_luci-app-qbittorrent=n
CONFIG_PACKAGE_luci-app-transmission=n
CONFIG_PACKAGE_luci-app-clouddrive2=n
CONFIG_PACKAGE_luci-app-samba4=n
CONFIG_PACKAGE_luci-app-sqm-autorate=n
CONFIG_PACKAGE_luci-app-mwan3=n
CONFIG_PACKAGE_luci-app-syncdial=n
CONFIG_PACKAGE_luci-app-iptvhelper=n
CONFIG_PACKAGE_luci-app-ksmbd=n
CONFIG_PACKAGE_luci-app-filebrowser=n

# 网络内核依赖
CONFIG_PACKAGE_kmod-ipt-conntrack=y
CONFIG_PACKAGE_kmod-ipt-core=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-ipset=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y

# 禁用MTK/其他无线驱动
CONFIG_PACKAGE_kmod-mt_wifi=n
